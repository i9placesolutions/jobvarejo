{
  "buildCommand": "npm run build",
  "outputDirectory": ".output/public",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "nuxt",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    ".output/server/**/*.mjs": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
