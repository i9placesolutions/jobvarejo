# Supabase (client/public)
# Use a URL do projeto (Settings > API)
NUXT_PUBLIC_SUPABASE_URL=

# Use a chave anon (JWT) do projeto (Settings > API > Project API keys > anon)
NUXT_PUBLIC_SUPABASE_KEY=

# Supabase (server only)
# Necessária apenas para rotas/admin que exigem service role.
SUPABASE_SERVICE_ROLE_KEY=


# ============================================================================
# WASABI CLOUD STORAGE (Primary Storage)
# ============================================================================
# Wasabi é compatível com AWS S3 e usado para armazenar arquivos pesados
# Endpoint: s3.wasabisys.com (ou sua região específica)
WASABI_ENDPOINT=s3.wasabisys.com
WASABI_BUCKET=jobvarejo
WASABI_ACCESS_KEY=154MD4JFJPF61INBCUKT
WASABI_SECRET_KEY=XeyNjaMt7IAzJNdG2caSGPm5yCwC4Qa6U1hAS05R
WASABI_REGION=us-east-1

# ============================================================================
# ESTRUTURA DE PASTAS NO BUCKET WASABI
# ============================================================================
# jobvarejo/
# ├── projects/{userId}/{projectId}/
# │   ├── page_{pageId}.json    → Canvas JSON (auto-save)
# │   └── thumb_{pageId}.png    → Thumbnails
# ├── imagens/{filename}       → Uploads de imagens
# └── logo/{filename}           → Logos de marcas


# ============================================================================
# CONTABO STORAGE (Legacy - mantido para compatibilidade temporária)
# ============================================================================
# Se ainda estiver migrando da Contabo, mantenha estas variáveis.
# Caso contrário, pode remover.
CONTABO_ENDPOINT=
CONTABO_REGION=default
CONTABO_BUCKET=
CONTABO_ACCESS_KEY=
CONTABO_SECRET_KEY=
CONTABO_BRANDS_BUCKET=
CONTABO_IMPORT_BUCKET=


# OpenAI / Serper (opcional, dependendo das features)
# Server-only (NÃO use prefixo NUXT_PUBLIC_)
NUXT_OPENAI_API_KEY=

# Alternativa/compatibilidade (o nuxt.config.ts também aceita esse nome)
OPENAI_API_KEY=

NUXT_SERPER_API_KEY=


# ============================================
# OTIMIZAÇÕES PARA DEPLOY VERCEL
# ============================================
# Adicione estas variáveis nas Environment Variables do projeto Vercel
# para resolver o erro de tamanho de bundle

# Otimização de memória para build
NODE_OPTIONS=--max-old-space-size=4096

# Ignorar Sharp global (reduz bundle)
SHARP_IGNORE_GLOBAL_LIBVIPS=true

# Ambiente de produção
NODE_ENV=production
